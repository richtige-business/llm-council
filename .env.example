# Environment Variables - Example Template
# Kopiere diese Datei zu .env.local und fülle deine echten Keys ein

# Database (PostgreSQL)
# Lokal: postgresql://USER:PASS@localhost:5432/lifeos
# Cloud: Neon, Supabase, etc.
DATABASE_URL=postgresql://localhost/lifeos

# LLM Provider API Keys
# Wähle einen Provider: "anthropic" oder "openai"

# Anthropic Claude API Key
# Hole dir einen Key auf: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key_here

# OpenRouter API Key (wird ueber OPENAI-kompatiblen Client genutzt)
# Hole dir einen Key auf: https://openrouter.ai/keys
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Standard Provider (optional, Standard: "openai" fuer OpenRouter)
LLM_PROVIDER=openai

# Web-Search Skill fuer Council-Mitglieder
# Hole dir einen kostenlosen Key auf: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Cloud Browser Streaming Service (WebRTC/Stream-Manager)
# Leer lassen fuer internes Next.js /api/streams Backend
# oder auf externe Domain setzen (z.B. https://stream.lifeos.app)
NEXT_PUBLIC_STREAM_SERVICE_URL=

# Lokaler Stream-Manager Service (wird vom internen /api/streams Backend genutzt)
# Die alte APP_RUNNER-Variable bleibt als Fallback kompatibel.
NEXT_PUBLIC_STREAM_MANAGER_SERVICE_URL=http://127.0.0.1:3002
NEXT_PUBLIC_APP_RUNNER_SERVICE_URL=http://127.0.0.1:3002
