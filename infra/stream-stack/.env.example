# ============================================
# .env.example - Stream Stack Deployment Variablen
#
# Zweck: Vorlage fuer produktive Deployment-Konfiguration
# Verwendet von: docker-compose.yml, caddy reverse proxy
# ============================================

# Oeffentliche Domain der Haupt-App (Next.js)
APP_DOMAIN=lifeos.example.com

# Oeffentliche Domain fuer optionalen externen Stream-Endpunkt
STREAM_DOMAIN=stream.lifeos.example.com

# Interner Port der Next.js App
APP_PORT=3000

# Interner Port des Stream-Manager-Service
APP_RUNNER_PORT=3002

# Lokale Postgres-Datenbank fuer den Stream-Stack
POSTGRES_DB=lifeos
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=change-this-password

# Frontend-URL fuer CORS und oeffentliche Viewer-Links
FRONTEND_URL=https://lifeos.example.com

# Optional: explizite Basis-URL fuer Viewer-Links
# Standardmaessig wird FRONTEND_URL verwendet.
STREAM_PUBLIC_BASE_URL=https://lifeos.example.com

# Oeffentliche Server-IP fuer WebRTC ICE-Kandidaten.
# Bei Domain-Betrieb trotzdem die echte oeffentliche IP eintragen.
STREAM_WEBRTC_PUBLIC_IP=88.99.141.234

# Optional: separate Stream-URL fuer Frontend
NEXT_PUBLIC_STREAM_SERVICE_URL=
