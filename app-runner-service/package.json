{
  "name": "lifeos-stream-manager-service",
  "version": "1.0.0",
  "description": "Schlanker Stream-Manager fuer LifeOS Web-App-Streaming",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/stream-manager.ts",
    "dev:legacy": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/stream-manager.js",
    "start:legacy": "node dist/index.js",
    "build:helper": "cd capture-helper && ./build.sh",
    "build:helper:debug": "cd capture-helper && ./build.sh debug",
    "build:all": "npm run build:helper && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "http-proxy": "^1.18.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
